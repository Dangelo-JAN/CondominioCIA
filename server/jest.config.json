{
  "testEnvironment": "node",
  "testMatch": ["**/tests/**/*.test.js"],
  "coverageDirectory": "coverage",
  "transform": {},
  "moduleFileExtensions": ["js", "mjs"],
  "testPathIgnorePatterns": ["/node_modules/"],
  "collectCoverageFrom": [
    "controllers/**/*.js",
    "routes/**/*.js",
    "!**/node_modules/**"
  ]
}